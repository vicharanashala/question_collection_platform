# Application
NODE_ENV=development
PORT=3000
# OTP_RATE_LIMIT=true   # Set to false to disable per-mobile OTP rate-limiting in dev
# THROTTLE_ENABLED=true # Set to false to disable NestJS global throttle in dev

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=question_platform

# JWT
JWT_SECRET=change-me-in-production-use-strong-random-secret
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SMS Gateway
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=AGRIAPP