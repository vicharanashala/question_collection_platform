# Application
NODE_ENV=development
PORT=3000
# OTP_RATE_LIMIT=true   # Set to false to disable per-mobile OTP rate-limiting in dev
# THROTTLE_ENABLED=true # Set to false to disable NestJS global throttle in dev

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=question_platform

# JWT
JWT_SECRET=change-me-in-production-use-strong-random-secret
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SMS Gateway
# SMS_PROVIDER=mock|fast2sms|msg91|twilio|gupshup  (default: mock - logs to console, no external call)
SMS_PROVIDER=mock
SMS_API_KEY=          # Fallback SMS API key (used if FAST2SMS_API_KEY not set)
SMS_API_SECRET=       # Used by Twilio/Gupshup
SMS_SENDER_ID=AGRIAPP # Fallback sender name

# Fast2SMS (used when SMS_PROVIDER=fast2sms)
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=Annam.Ai
FAST2SMS_ROUTE=otp

# Sarvam AI (Speech-to-Text & Translate)
SARVAM_API_KEY=
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TRANSLATE_URL=https://api.sarvam.ai/translate


# LGD (To fetch districts, sub-districts, and states data)
LGD_API_KEY=<YOUR_LGD_API_KEY>    
LGD_DISTRICTS_API_URL=https://api.data.gov.in/resource/37231365-78ba-44d5-ac22-3deec40b9197                                     
LGD_SUBDISTRICTS_API_URL=https://api.data.gov.in/resource/6be51a29-876a-403a-a6da-42fde795e751                                 
LGD_STATES_API_URL=https://api.data.gov.in/resource/a71e60f0-a21d-43de-a6c5-fa5d21600cdb                                        

# PineLabs Payment Gateway
PINELABS_ENV=sandbox                       # 'sandbox' for dev/test, 'production' for live
PINELABS_MERCHANT_ID=125615
PINELABS_API_KEY=19928cb2-7caf-4d5a-988b-b3d3bf79d653
PINELABS_SECRET_KEY=1afb3b0c8f394dc68521da3624cb97b0
PINELABS_WEBHOOK_SECRET=                   # Optional: for verifying incoming webhook signatures
